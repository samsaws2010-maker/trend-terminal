# The Trend Terminal — Environment Variables

# Required for the Node API server
PORT=8080

# Python classifier service port (default: 5100)
PYTHON_SERVICE_PORT=5100

# Frontend port (default: 5173)
PORT=5173

# Base URL path for the frontend (default: /)
BASE_PATH=/

# Optional: OpenAI API key for the AI classifier fallback
# Get one at https://platform.openai.com
# OPENAI_API_KEY=sk-...

# Optional: Database connection (PostgreSQL)
# Only needed if you add persistent storage features
# DATABASE_URL=postgresql://user:pass@localhost:5432/trend_terminal
