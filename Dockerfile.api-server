FROM node:24-alpine

WORKDIR /app

# Install pnpm
RUN npm install -g pnpm

# Copy package files
COPY package.json .
COPY pnpm-workspace.yaml .
COPY tsconfig.json .
COPY tsconfig.base.json .

# Copy workspace code
COPY lib ./lib
COPY artifacts/api-server ./artifacts/api-server
COPY scripts ./scripts

# Install dependencies (clean + Render-safe)
ENV PNPM_ENABLE_SCRIPTS=1
ENV PNPM_CONFIG_IGNORE_SCRIPTS=false
ENV PNPM_STRICT_PEER_DEPENDENCIES=false

RUN pnpm install --no-frozen-lockfile

# Build ONLY API server (IMPORTANT)
RUN pnpm -C artifacts/api-server install
RUN pnpm -C artifacts/api-server build

# Expose API port
EXPOSE 8080

# Environment variables
ENV PORT=8080
ENV PYTHON_SERVICE_PORT=5100
ENV PYTHON_SERVICE_HOST=classifier
ENV BASE_PATH=/api

# Start server
CMD ["node", "artifacts/api-server/dist/index.js"]