# ── WSB Posts ──────────────────────────────────────────────────────────────────

@app.route("/internal/wsb/posts")
def list_posts():
    global df
    if df.empty:
        return jsonify({"posts": [], "total": 0, "offset": 0, "limit": 50})

    sentiment_filter = request.args.get("sentiment")
    search = request.args.get("search", "").strip().lower()
    limit = int(request.args.get("limit", 50))
    offset = int(request.args.get("offset", 0))

    filtered = df.copy()
    if sentiment_filter:
        filtered = filtered[filtered["sentiment"] == sentiment_filter]
    if search:
        filtered = filtered[filtered["title"].str.lower().str.contains(search, na=False)]

    total = len(filtered)
    page = filtered.iloc[offset: offset + limit]

    posts = []
    for _, row in page.iterrows():
        date_val = row.get("date_utc")
        if hasattr(date_val, "isoformat"):
            date_str = date_val.isoformat()
        else:
            date_str = str(date_val) if date_val is not None and str(date_val) != "nan" else None

        score_val = row.get("score")
        try:
            score_int = int(score_val) if score_val is not None and not (isinstance(score_val, float) and math.isnan(score_val)) else None
        except (TypeError, ValueError):
            score_int = None

        num_comments_val = row.get("num_comments")
        try:
            nc_int = int(num_comments_val) if num_comments_val is not None and not (isinstance(num_comments_val, float) and math.isnan(num_comments_val)) else None
        except (TypeError, ValueError):
            nc_int = None

        ticker_val = row.get("ticker")
        ticker_str = str(ticker_val) if ticker_val is not None and str(ticker_val) not in ("nan", "None", "") else None

        flair_val = row.get("flair")
        flair_str = str(flair_val) if flair_val is not None and str(flair_val) not in ("nan", "None", "") else None

        posts.append({
            "post_id": str(row.get("post_id", "")),
            "title": str(row.get("title", "")),
            "flair": flair_str,
            "score": score_int,
            "num_comments": nc_int,
            "date_utc": date_str,
            "url": str(row.get("url")) if row.get("url") and str(row.get("url")) not in ("nan", "None", "") else None,
            "ticker": ticker_str,
            "sentiment": str(row.get("sentiment", "Neutral")),
            "classification_method": str(row.get("classification_method")) if row.get("classification_method") and str(row.get("classification_method")) not in ("nan", "None") else None,
        })

    return jsonify({"posts": posts, "total": total, "offset": offset, "limit": limit})


@app.route("/internal/wsb/summary")
