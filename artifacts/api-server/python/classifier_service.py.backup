@app.route("/internal/wsb/top-tickers")
def top_tickers():
    global df
    n = int(request.args.get("limit", 10))
    if df.empty:
        return jsonify([])
    tickers_df = get_top_tickers(df, n)
    if tickers_df.empty:
        return jsonify([])
    rows = []
    for _, row in tickers_df.iterrows():
        rows.append({
            "ticker": str(row["ticker"]),
            "mention_count": int(row["mention_count"]),
            "positive_pct": float(row.get("positive_pct", 0)),
            "negative_pct": float(row.get("negative_pct", 0)),
            "neutral_pct": float(row.get("neutral_pct", 0)),
            "dominant_sentiment": str(row.get("dominant_sentiment", "Neutral")),
        })
    return jsonify(rows)


@app.route("/internal/wsb/recent-activity")
def recent_activity():
    global df
    limit = int(request.args.get("limit", 20))
    if df.empty:
        return jsonify([])

    filtered = df.copy()
    if "date_utc" in filtered.columns:
        filtered = filtered.sort_values("date_utc", ascending=False)
    page = filtered.head(limit)

    posts = []
    for _, row in page.iterrows():
        date_val = row.get("date_utc")
        if hasattr(date_val, "isoformat"):
            date_str = date_val.isoformat()
        else:
            date_str = str(date_val) if date_val is not None and str(date_val) != "nan" else None

        score_val = row.get("score")
        try:
            score_int = int(score_val) if score_val is not None and not (isinstance(score_val, float) and math.isnan(score_val)) else None
        except (TypeError, ValueError):
            score_int = None

        ticker_val = row.get("ticker")
        ticker_str = str(ticker_val) if ticker_val is not None and str(ticker_val) not in ("nan", "None", "") else None

        flair_val = row.get("flair")
        flair_str = str(flair_val) if flair_val is not None and str(flair_val) not in ("nan", "None", "") else None

        posts.append({
            "post_id": str(row.get("post_id", "")),
            "title": str(row.get("title", "")),
            "flair": flair_str,
            "score": score_int,
            "num_comments": None,
            "date_utc": date_str,
            "url": str(row.get("url")) if row.get("url") and str(row.get("url")) not in ("nan", "None", "") else None,
            "ticker": ticker_str,
            "sentiment": str(row.get("sentiment", "Neutral")),
            "classification_method": None,
        })
    return jsonify(posts)


@app.route("/internal/wsb/sentiment-over-time")
def sentiment_over_time():
    global df
    if df.empty or "date_utc" not in df.columns:
        return jsonify([])

    tmp = df.copy()
    tmp["date"] = pd.to_datetime(tmp["date_utc"], errors="coerce").dt.date
    tmp = tmp.dropna(subset=["date"])

    grouped = tmp.groupby(["date", "sentiment"]).size().unstack(fill_value=0).reset_index()
    for col in ["Positive", "Negative", "Neutral"]:
        if col not in grouped.columns:
            grouped[col] = 0

    result = []
    for _, row in grouped.iterrows():
        result.append({
            "date": str(row["date"]),
            "Positive": int(row.get("Positive", 0)),
            "Negative": int(row.get("Negative", 0)),
            "Neutral": int(row.get("Neutral", 0)),
        })
    return jsonify(result)


