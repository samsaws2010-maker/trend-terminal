# ── Load data once at startup ──────────────────────────────────────────────────
df: pd.DataFrame = pd.DataFrame()

def _load_data():
    global df
    try:
        df = load_labeled_data(str(EXTRACTED_DIR / "wsb_labeled.csv"))
        # Ensure ticker column exists
        if "ticker" not in df.columns:
            df["ticker"] = None
